  <property name="styleSheet">
   <string notr="true">/* Fondo general */
QWidget {
    background-color: #1e1e2f;
    color: #f0f0f0;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    font-size: 14px;
}

/* Botones */
QPushButton {
    background-color: #3a3f5a;
    border: none;
    border-radius: 8px;
    padding: 6px 12px;
}

QPushButton:hover {
    background-color: #50577a;
}

QPushButton:pressed {
    background-color: #2c3147;
}

/* Inputs */
QLineEdit, QTextEdit, QPlainTextEdit {
    background-color: #2a2f45;
    border: 1px solid #3f4662;
    border-radius: 6px;
    padding: 6px;
}

/* Labels */
QLabel {
    color: #e0e0e0;
}

/* ComboBox */
QComboBox {
    background-color: #2a2f45;
    border: 1px solid #3f4662;
    border-radius: 6px;
    padding: 5px;
}

QComboBox::drop-down {
    border: none;
}

/* Scrollbar */
QScrollBar:vertical {
    background: #1e1e2f;
    width: 10px;
    margin: 2px;
}

QScrollBar::handle:vertical {
    background: #3a3f5a;
    border-radius: 5px;
}

QScrollBar::handle:vertical:hover {
    background: #50577a;
}

/* CheckBox */
QCheckBox {
    spacing: 6px;
}

QCheckBox::indicator {
    width: 14px;
    height: 14px;
}

QCheckBox::indicator:checked {
    background-color: #6c8cff;
    border-radius: 3px;
}

/* Tabs */
QTabWidget::pane {
    border: 1px solid #3f4662;
}

QTabBar::tab {
    background: #2a2f45;
    padding: 8px;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
}

QTabBar::tab:selected {
    background: #3a3f5a;
}

/* Tooltips */
QToolTip {
    background-color: #3a3f5a;
    color: #ffffff;
    border: 1px solid #6c8cff;
}</string>
